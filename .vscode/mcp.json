{
  "$schema": "vscode://schemas/mcp",
  "inputs": [
    {
      "type": "promptString",
      "id": "github_mcp_pat",
      "description": "Fine-grained GitHub token (repo + workflow + contents access)",
      "password": true
    }
  ],
  "servers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_TOKEN": "${input:github_mcp_pat}"
      }
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem"]
    },
    "git": {
      "command": "uvx",
      "args": ["mcp-server-git"]
    },
    "shell": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-terminal",
        "--chdir",
        "${workspaceFolder}",
        "--allow",
        "git",
        "--allow",
        "gh",
        "--allow",
        "terraform",
        "--allow",
        "aws",
        "--allow",
        "python3",
        "--allow",
        "pytest",
        "--allow",
        "make"
      ]
    }
  }
}
