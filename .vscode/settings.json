{
  // --- MCP behaviour ---
  "chat.mcp.discovery.enabled": {
    "claude-desktop": false,
    "windsurf": false,
    "cursor-global": false,
    "cursor-workspace": false
  },     // stop VS Code from auto-discovering other MCP servers
  "chat.mcp.access": "registry",           // only load servers declared in this workspace’s mcp.json
  "chat.mcp.autostart": true,              // start all MCP servers when you open the workspace
  "chat.agent.enabled": true,              // keep Agent Mode on so Copilot Chat can call tools

  // --- Network / proxy / TLS ---
  "http.systemCertificates": true,         // trust macOS Keychain root certificates
  "http.proxyStrictSSL": false,            // temporarily relax strict SSL for corp TLS inspection
  "http.proxySupport": "on",               // let VS Code honour system proxy env vars
  // if you know the proxy host, uncomment & fill this line:
  // "http.proxy": "http://proxy.mycorp.local:8080",

  // --- Editor UX (optional quality of life) ---
  "editor.codeLens": true,
  "editor.formatOnSave": true,
  "files.trimTrailingWhitespace": true
}
