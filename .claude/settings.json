{
  "projectName": "Enterprise with Guardrails & Mandatory Atlassian",
  "description": "Infrastructure enforcement + documentation + issue tracking",
  
  "permissions": {
    "comment": "Prevent repeated permission prompts - once granted, cached for session",
    "cacheGrantedPermissions": true,
    "skipRepeatPrompts": true,
    "bypassConfirmationFor": [
      "bash",
      "file_operations",
      "git_operations",
      "network_requests"
    ],
    "permissionCacheTTL": 3600,
    "comment_note": "These are safe operations in your enterprise repos - enforce via hooks instead"
  },

  "hooks": {
    "preCommit": [
      {
        "comment": "Block direct CLI infrastructure changes",
        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-direct-cli.sh"
      },
      {
        "comment": "Block security pattern removal",
        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-security-removal.sh"
      },
      {
        "comment": "Block error handling removal",
        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-error-handling-removal.sh"
      },
      {
        "comment": "Require ADR for security changes",
        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/require-adr-for-security-changes.sh"
      },
      {
        "comment": "MANDATORY: Documentation in Confluence, not local markdown",
        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/require-confluence.sh"
      },
      {
        "comment": "MANDATORY: Issues tracked in Jira, not TODO comments",
        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/require-jira.sh"
      }
    ],
    "postCommit": [
      {
        "comment": "Validate terraform state after commit",
        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/validate-terraform-drift.sh"
      },
      {
        "comment": "Suggest Confluence sync for new ADRs",
        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/update-confluence-adr.sh"
      }
    ]
  },

  "customCommands": {
    "confluence-search": "Search Confluence: /confluence-search <query>",
    "confluence-create": "Create Confluence page: /confluence-create --title <title> --space <space> --body <content>",
    "confluence-update": "Update Confluence page: /confluence-update --page-id <id> --body <content>",
    "jira-search": "Search Jira: /jira-search <query>",
    "jira-create": "Create Jira issue: /jira-create --project <key> --type <type> --summary <summary> --description <desc>",
    "jira-transition": "Transition Jira issue: /jira-transition <issue-key> --status <status>",
    "jira-link": "Link Jira issues: /jira-link <from-key> <to-key> --type <type>"
  },

  "skillDefaults": {
    "comment": "Force Jira and Confluence skills to use MCP servers exclusively - no manual auth prompts",
    "jira": {
      "authMethod": "mcp",
      "mcpServerName": "atlassian-cloud"
    },
    "confluence": {
      "authMethod": "mcp",
      "mcpServerName": "atlassian-cloud"
    }
  },

  "comment": "All hooks are MANDATORY (exit code 2) - no bypassing infrastructure, security, or Atlassian enforcement"
}
