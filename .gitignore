*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# --- Virtual Environments ---
.venv/
venv/
.venv_smoke/
env/
ENV/

# --- Testing & Quality ---
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- IDEs & Editors ---
.vscode/
.idea/
*.swp
*.swo

# --- awsctl Specifics ---
tools/output/
tools/smoke_artifacts/
*.log
audit.log

# --- Security & Credentials ---
